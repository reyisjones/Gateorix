{
  "name": "hello-svelte-cpp",
  "version": "0.1.0",
  "frontend": {
    "devUrl": "http://localhost:5173",
    "entry": "dist/index.html"
  },
  "runtime": {
    "type": "cpp",
    "entry": "backend/main.cpp",
    "build": "cd backend && mkdir -p build && cd build && cmake .. && cmake --build ."
  },
  "permissions": {
    "filesystem": ["./data"],
    "process": false,
    "notifications": true,
    "clipboard": true
  },
  "windows": [
    {
      "id": "main",
      "title": "Hello Gateorix — C++",
      "width": 1200,
      "height": 800
    }
  ]
}
