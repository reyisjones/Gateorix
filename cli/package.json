{
  "name": "@gateorixjs/cli",
  "version": "0.3.1",
  "description": "Gateorix CLI — scaffold, develop, and build Gateorix desktop applications",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reyisjones/Gateorix.git",
    "directory": "cli"
  },
  "bin": {
    "gateorix": "dist/index.js",
    "gx": "dist/index.js"
  },
